---
import { site, type Lang } from '../data/site';
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section hero" aria-labelledby="hero-name">
  <div class="hero-grid">
    <div class="hero-copy">
      {
        site.openToWork && (
          <p class="pill pill-live" aria-label={t('hero.openToWork')}>
            <span class="dot" />
            {t('hero.openToWork')}
          </p>
        )
      }

      <h1 id="hero-name">{site.name}</h1>

      <!--
        TODO: hero tagline
        Supply one strong positioning line + one supporting line.
        Replace the two <p> blocks below. Keep the first bold/large, second muted.
      -->
      <p class="tagline">TODO: hero tagline — one strong positioning line goes here.</p>
      <p class="tagline-sub">
        TODO: hero tagline — one supporting line goes here.
      </p>

      <p class="hero-meta">
        <span aria-hidden="true">📍</span> {t('hero.location')}
      </p>

      <div class="hero-cta">
        <a class="btn btn-primary" href={`mailto:${site.email}`}>{t('hero.ctaContact')}</a>
        <a class="btn btn-ghost" href={site.resumePdf}>{t('hero.ctaResume')}</a>
      </div>
    </div>

    <div class="hero-photo">
      <div class="photo-frame">
        <img src={site.photo} alt={t('hero.photoAlt')} width="512" height="512" loading="eager" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    border-top: none;
    padding-top: clamp(1rem, 4vw, 2rem);
  }
  .hero-grid {
    display: grid;
    gap: 1.75rem;
  }
  .tagline {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 4.5vw, 1.6rem);
    line-height: 1.3;
    color: var(--ink);
    margin: 0.75rem 0 0.5rem;
  }
  .tagline-sub {
    font-size: 1.05rem;
    color: var(--ink-soft);
    margin: 0 0 1.25rem;
  }
  .hero-meta {
    font-size: 0.95rem;
    color: var(--ink-faint);
    margin: 0 0 1.5rem;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .hero-photo {
    order: -1; /* photo on top on mobile */
  }
  .photo-frame {
    width: clamp(7rem, 34vw, 9rem);
    aspect-ratio: 1;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: var(--surface);
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Portrait source — bias the crop toward the top so the face stays in frame.
       Adjust this if the crop cuts off the head/chin. */
    object-position: center 25%;
    display: block;
  }

  /* On wider screens: text left, photo right. */
  @media (min-width: 40rem) {
    .hero-grid {
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 2.5rem;
    }
    .hero-photo {
      order: 0;
    }
    .photo-frame {
      width: clamp(9rem, 22vw, 12rem);
    }
  }
</style>
